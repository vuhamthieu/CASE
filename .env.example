# CASE local environment overrides
# Copy this file to .env and fill in values for your machine.
#
# Stable non-secret defaults live in src/config/defaults.py.
# Keep .env limited to secrets and machine-specific hardware choices.

# Required for Gemini text/cloud STT features.
GEMINI_API_KEY=

# Normal Raspberry Pi runtime.
CASE_VOICE_MODE=realtime

# Optional: force specific Raspberry Pi audio devices.
# Find device names with:
#   python3 -m sounddevice
CASE_AUDIO_INPUT_DEVICE="USB PnP Sound Device"
CASE_AUDIO_OUTPUT_DEVICE="MAX98357A"
