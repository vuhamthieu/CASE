# CASE local environment overrides
# Copy this file to .env and fill in values for your machine.
#
# Most runtime defaults live in src/config/defaults.py.
# Keep .env for secrets and local hardware overrides.

# Required for Gemini text/realtime features.
GEMINI_API_KEY=

# Optional: force specific Raspberry Pi audio devices.
# Find device names with:
#   python3 -m sounddevice
# Examples:
#   CASE_AUDIO_INPUT_DEVICE=USB PnP Sound Device
#   CASE_AUDIO_OUTPUT_DEVICE=MAX98357A
CASE_AUDIO_INPUT_DEVICE=
CASE_AUDIO_OUTPUT_DEVICE=

# Optional console mode: clean or debug.
CASE_CONSOLE_MODE=clean

# Optional runtime mode overrides.
CASE_VOICE_MODE=realtime
REALTIME_PROVIDER=gemini_live
